{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "distillation.channel.schema.json",
  "title": "Distillation Channel Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["essence", "key_points"],
  "properties": {
    "essence": { "type": "string", "minLength": 1 },
    "key_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["point", "importance"],
        "properties": {
          "point": { "type": "string", "minLength": 1 },
          "importance": { "type": "number", "minimum": 0, "maximum": 1 },
          "rationale": { "type": "string" }
        }
      }
    },
    "omitted": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
