{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "steelman.channel.schema.json",
  "title": "Steelman Channel Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["positions"],
  "properties": {
    "positions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "best_support", "confidence"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "best_support": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  }
}
