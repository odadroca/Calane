{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "distillation.synthesis.schema.json",
  "title": "Distillation Synthesis Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["distilled_summary", "consensus_points"],
  "properties": {
    "distilled_summary": { "type": "string", "minLength": 1 },
    "consensus_points": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["point", "agreement"],
        "properties": {
          "point": { "type": "string", "minLength": 1 },
          "agreement": { "type": "string", "enum": ["unanimous", "majority", "split"] },
          "supporting_models": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "divergences": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topic", "positions"],
        "properties": {
          "topic": { "type": "string", "minLength": 1 },
          "positions": { "type": "string", "minLength": 1 }
        }
      }
    },
    "openQuestions": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
