{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "surviving_position.synthesis.schema.json",
  "title": "Surviving Position Synthesis Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["positions"],
  "properties": {
    "positions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "support", "dissent_responses", "survives", "confidence"],
        "properties": {
          "claim": { "type": "string", "minLength": 1 },
          "support": { "type": "string", "minLength": 1 },
          "dissent_responses": {
            "type": "array",
            "items": { "type": "string" }
          },
          "survives": { "type": "boolean" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "summary": { "type": "string" }
  }
}
