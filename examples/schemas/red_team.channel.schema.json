{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "red_team.channel.schema.json",
  "title": "Red Team Channel Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["attacks"],
  "properties": {
    "attacks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["vector", "impact", "likelihood"],
        "properties": {
          "vector": { "type": "string", "minLength": 1 },
          "impact": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "likelihood": { "type": "number", "minimum": 0, "maximum": 1 },
          "mitigation": { "type": "string" }
        }
      }
    }
  }
}
