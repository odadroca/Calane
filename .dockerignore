# Build context = only the files actually needed to install deps, build, and run.
# Everything else (history, docs, local state, tests, editor noise) is excluded
# so the context upload to the daemon stays small and rebuilds stay fast.

# ---- VCS ----
.git
.gitignore
.gitattributes

# ---- Will be regenerated by `pnpm install` / `pnpm build` inside the image ----
**/node_modules
**/dist
**/*.tsbuildinfo
coverage

# ---- Local runtime output / state (must not leak into the image) ----
.runs
runs
run_bundles
.claude
.CALANE
.CALANE-sandbox
*.log

# ---- Tests (not run in the image; tsup builds from src only) ----
**/tests
**/*.test.ts
vitest.config.ts

# ---- Editor / OS noise ----
.vscode
.idea
.DS_Store
Thumbs.db

# ---- Process docs / governance markdown (not needed at build or runtime) ----
docs
CLAUDE.md
README.md
HANDOVER.md
DEVIATIONS.md
STATUS.md
00-PLAN.md
01-ORCHESTRATOR.md
02-PHASE-LEAD.md
03-SPRINT-WORKER.md
04-GUARDRAILS.md
05-COMMANDS.md
06-PHASE2-HARDENING.md
07-PHASE3-OPERATIONAL-MATURITY.md
08-PHASE4-ANALYTICAL-SURFACE.md
09-PHASE5-CROSS-RUN-REASONING.md
10-PHASE6-NETWORK-LAYER.md

# ---- Lint config (not needed once the code is built) ----
biome.json

# ---- Alternative deployment targets / Docker meta (not needed inside the image) ----
render.yaml
Dockerfile
.dockerignore
docker-compose*.yml
.github
